# ===== Exemple de configuration backend DZnutri =====
# Copier en `.env` et remplir. NE PAS committer le vrai `.env`.

# --- Base de données ---
# En local/dev contre Neon : URL complète Neon (SSL auto-activé).
# En Docker : laissée vide / ignorée (docker-compose fournit DATABASE_URL).
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname

# SSL: true pour Neon/distant, false pour Postgres local/Docker.
# Si non défini, auto-détecté à partir de l'hôte.
# DB_SSL=true

# Pool de connexions (optionnel)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_RECYCLE=1800
# SQL_ECHO=false

# --- Cache ---
# En Docker, fourni par docker-compose (redis://redis:6379).
# En local sans Redis, l'app bascule automatiquement en cache mémoire.
# REDIS_URL=redis://localhost:6379

# --- Rate limiting (anti-brute-force) ---
# Compteurs en mémoire par défaut (par worker). En multi-workers/instances,
# pointer vers Redis pour partager les limites entre les process.
# RATELIMIT_STORAGE_URI=redis://redis:6379

# --- Variables propres au docker-compose (service db) ---
POSTGRES_USER=dznutri
POSTGRES_PASSWORD=change_me_in_production   # OBLIGATOIRE : compose échoue si vide
POSTGRES_DB=dznutri

# Chemin HÔTE de la clé Google Vision (OCR), montée en lecture seule dans le
# conteneur par docker-compose. Défaut : ./dznutri-632fbb70c039.json
# VISION_KEY_FILE=./dznutri-632fbb70c039.json

# --- Divers ---
ENVIRONMENT=development      # "production" pour restreindre le CORS
LOG_LEVEL=INFO
# Origines autorisées en production (CORS), séparées par des virgules.
# Ex: https://admin.dznutri.com,https://app.dznutri.com
# ALLOWED_ORIGINS=

# --- Cloudinary (upload d'images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Auth ---
# OBLIGATOIRE en production (>= 32 caractères). L'app refuse de démarrer sinon.
# Générer : python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
# Durée de vie des tokens en minutes (défaut 43200 = 30 jours)
# ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- Email (réinitialisation mot de passe) ---
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
